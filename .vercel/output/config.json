{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/account/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/account/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/account-points/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/forgot-password/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/debug-env/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/products/?$",
			"dest": "_render"
		},
		{
			"src": "^/coa/?$",
			"dest": "_render"
		},
		{
			"src": "^/forgot-password/?$",
			"dest": "_render"
		},
		{
			"src": "^/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/restock-status/?$",
			"dest": "_render"
		},
		{
			"src": "^/shop/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}