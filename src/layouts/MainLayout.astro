---
import "../styles/global.css";

import GlobalPreloader from "../components/loading/GlobalPreloader.jsx";
import AgeGate from "../components/age-gate/AgeGate.jsx";
import AffiliateCouponTracker from "../components/tracking/AffiliateCouponTracker.jsx";
import Popups from "../components/popups/pop.jsx";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const siteName = "Phase One Labz";
const siteUrl = "https://phaseonelabz.com";
const metaPixelId = "4340714472849976";

const {
  title = "Phase One Labz | Premium Research Peptides",
  description = "Phase One Labz provides premium research-use-only peptides and laboratory-focused products for qualified research, educational, and laboratory applications.",
  image = "/TRANSPARENCIA-03.webp",
  noindex = false,
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "");
const isHome = pathname === "";

const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(image, siteUrl).toString();

const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteName,
  url: siteUrl,
  logo: `${siteUrl}/TRANSPARENCIA-03.webp`,
  sameAs: [],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  url: siteUrl,
  description,
};
---

<!doctype html>
<html lang="en" class={isHome ? "is-home-page" : ""}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{fullTitle}</title>

    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"}
    />

    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" type="image/png" href="/favicon.png?v=6" />
    <link rel="shortcut icon" type="image/png" href="/favicon.png?v=6" />
    <link rel="apple-touch-icon" href="/favicon.png?v=6" />

    <meta name="theme-color" content="#020617" />
    <meta name="color-scheme" content="dark light" />

    <meta property="og:site_name" content={siteName} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={isHome ? "website" : "article"} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={`${siteName} research catalog`} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta
      name="classification"
      content="Research-use-only laboratory catalog"
    />
    <meta
      name="keywords"
      content="research peptides, laboratory peptides, research compounds, Phase One Labz, lab use only peptides, educational research peptides"
    />

    <link rel="preconnect" href="https://omnisnippet1.com" crossorigin />
    <link rel="preconnect" href="https://embed.tawk.to" crossorigin />
    <link rel="preconnect" href="https://connect.facebook.net" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />

    <script is:inline define:vars={{ metaPixelId }}>
      !(function (f, b, e, v, n, t, s) {
        if (f.fbq) return;
        n = f.fbq = function () {
          n.callMethod
            ? n.callMethod.apply(n, arguments)
            : n.queue.push(arguments);
        };
        if (!f._fbq) f._fbq = n;
        n.push = n;
        n.loaded = true;
        n.version = "2.0";
        n.queue = [];
        t = b.createElement(e);
        t.async = true;
        t.src = v;
        s = b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t, s);
      })(
        window,
        document,
        "script",
        "https://connect.facebook.net/en_US/fbevents.js"
      );

      fbq("init", metaPixelId);
      fbq("track", "PageView");
    </script>

    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=AW-18266891349"
    ></script>

    <script is:inline>
      window.dataLayer = window.dataLayer || [];

      function gtag() {
        dataLayer.push(arguments);
      }

      gtag("js", new Date());
      gtag("config", "AW-18266891349");
    </script>

    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationSchema)}
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
  </head>

  <body class={isHome ? "is-home-page" : ""}>
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`}
        alt=""
      />
    </noscript>

    <AffiliateCouponTracker client:load />

    <AgeGate
      client:load
      logoSrc="/TRANSPARENCIA-03.webp"
      underAgeRedirectUrl="https://www.google.com"
    />

    <GlobalPreloader client:load logoSrc="/TRANSPARENCIA-03.webp" />

    <script is:inline type="text/javascript">
      window.omnisend = window.omnisend || [];
      window.omnisend.push(["brandID", "6a20666d078df331c0cd01d7"]);
      window.omnisend.push(["track", "$pageViewed"]);

      function loadOmnisend() {
        if (window.__phaseOmnisendLoaded) return;
        window.__phaseOmnisendLoaded = true;

        var e = document.createElement("script");
        e.type = "text/javascript";
        e.async = true;
        e.defer = true;
        e.src = "https://omnisnippet1.com/inshop/launcher-v2.js";

        var t = document.getElementsByTagName("script")[0];
        t.parentNode.insertBefore(e, t);
      }

      if ("requestIdleCallback" in window) {
        requestIdleCallback(loadOmnisend, { timeout: 3500 });
      } else {
        window.addEventListener("load", function () {
          setTimeout(loadOmnisend, 1800);
        });
      }
    </script>

    <main class="site-main">
      <slot />
    </main>

    <Popups client:only="react" />
  </body>
</html>